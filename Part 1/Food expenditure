times_a_week = int(input("How many times a week do you eat at the student cafeteria? "))
price = float(input("The price of a typical student lunch? "))
spending = float(input("How much money do you spend on groceries in a week? "))

food_expenditure_weekly = price * times_a_week + spending
food_expenditure_daily = food_expenditure_weekly / 7

print("Average food expenditure:")
print(f"Daily: {food_expenditure_daily} euros")
print(f"Weekly: {food_expenditure_weekly} euros")
